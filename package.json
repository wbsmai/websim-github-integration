{
  "name": "websim-github-integration",
  "private": true,
  "scripts": {
    "lint": "biome check",
    "format": "biome check --write --linter-enabled=false",
    "typegen": "wrangler types ./src/worker-configuration.d.ts",
    "dev": "usts build --watch",
    "build": "astro build && usts build",
    "build:ci": "bunx --bun astro build --define=process.versions.node:\"24.3.0\" && usts build",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.3",
    "@octokit/auth-app": "^8.2.0",
    "astro": "^6.0.8",
    "octokit": "^5.0.5",
    "solid-js": "^1.9.11",
    "tailwindcss": "^4.2.2",
    "websim": "^0.1.0"
  },
  "devDependencies": {
    "@astrojs/solid-js": "^6.0.1",
    "@biomejs/biome": "2.4.8",
    "@gameroman/config": "^0.0.2",
    "@rolldown-plugin/solid": "^0.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@violentmonkey/types": "^0.3.2",
    "usts": "^0.1.0",
    "wrangler": "^4.76.0"
  },
  "overrides": {
    "esbuild": "^0.27.4",
    "unstorage": "alpha",
    "rolldown": "1.0.0-rc.10"
  }
}
