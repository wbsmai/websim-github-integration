{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "extends": ["@gameroman/config/biome"],
  "files": {
    "ignoreUnknown": false,
    "includes": ["**", "!src/worker-configuration.d.ts"]
  },
  "linter": {
    "rules": { "a11y": "off" },
    "domains": { "solid": "all" }
  },
  "overrides": [
    {
      "includes": ["wrangler.jsonc"],
      "json": { "formatter": { "trailingCommas": "all" } }
    }
  ]
}
